# Caddy image tag — pin to a known-good version.
# Releases: https://github.com/caddyserver/caddy/releases
CADDY_TAG=2.11.2-alpine

# Public hostname Caddy serves on. Must resolve to this host
# (DNS, mDNS, or /etc/hosts). Used as the site address in Caddyfile.
CADDY_DOMAIN=spark-1822.local

# Basic-auth credentials for netdata.${CADDY_DOMAIN}.
# Hash with: docker exec -it caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
NETDATA_BASIC_AUTH_USER=admin
NETDATA_BASIC_AUTH_HASH=
