{
	# Local-CA mode: Caddy issues its own root + leaf certs.
	# Install /data/caddy/pki/authorities/local/root.crt on each client.
	# Admin API is bound to 127.0.0.1:2019 inside the container by default.
}

# Snippets shared by every site. Reference with `import common_headers` etc.
(common_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

(default_log) {
	log {
		output stdout
		format console
	}
}

# One file per service. Drop a new <name>.caddyfile here, reload Caddy,
# and the new site is live.
import Caddyfile.d/*.caddyfile
