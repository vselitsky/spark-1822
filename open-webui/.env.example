# Image tags — pin to known-good versions.
# Releases: https://github.com/ollama/ollama/releases
#           https://github.com/open-webui/open-webui/releases
OLLAMA_TAG=0.23.2
OPEN_WEBUI_TAG=v0.9.5

# Open WebUI session secret. Generate with: openssl rand -hex 32
# REQUIRED — compose refuses to start if unset.
WEBUI_SECRET_KEY=

# Host port for Open WebUI (bound to 0.0.0.0 — accessible on LAN).
OPEN_WEBUI_PORT=8080

# Require login (true) or run open (false). Keep true.
WEBUI_AUTH=true

# Allow new user signups. Leave true for initial admin registration,
# then set to false and `docker compose up -d` to lock down.
ENABLE_SIGNUP=true

# Keep models loaded in VRAM after inactivity.
# Examples: "5m" (default), "-1" (forever), "0" (unload immediately).
OLLAMA_KEEP_ALIVE=5m
