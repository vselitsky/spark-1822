# Copy to .env on the host and customize.

# Pin the Tailscale image. Tags: https://hub.docker.com/r/tailscale/tailscale/tags
TAILSCALE_TAG=v1.86.5

# Auth key from https://login.tailscale.com/admin/settings/keys
# Recommended settings when minting:
#   • Reusable    : yes  (so re-creating the container doesn't burn a key)
#   • Ephemeral   : no   (node persists across restarts)
#   • Pre-approved: yes  (skip manual approval in the admin console)
#   • Tags        : tag:server  (or whatever ACL tag fits your tailnet)
# Treat as a secret; .env is gitignored.
TS_AUTHKEY=

# Hostname this node registers as on the tailnet.
# Becomes https://<hostname>.<tailnet>.ts.net once MagicDNS publishes it.
TS_HOSTNAME=spark-1822
