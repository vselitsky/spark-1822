{
  "TCP": {
    "80": {
      "HTTP": true
    },
    "443": {
      "HTTPS": true
    }
  },
  "Web": {
    "${TS_CERT_DOMAIN}:80": {
      "Handlers": {
        "/": {
          "Proxy": "http://traefik:80"
        }
      }
    },
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/": {
          "Proxy": "https-insecure://traefik:443"
        }
      }
    }
  },
  "AllowFunnel": {
    "${TS_CERT_DOMAIN}:80": false,
    "${TS_CERT_DOMAIN}:443": false
  }
}
