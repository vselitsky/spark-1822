# Copy to .env on the host and customize.

# Pin the Traefik image. https://hub.docker.com/_/traefik/tags
# v2.11 is the LTS line — bundles a Docker SDK that auto-negotiates the
# host's API version (v3.3 ships a stale SDK that gets refused by modern
# Docker daemons with "client version 1.24 is too old").
TRAEFIK_TAG=v2.11
