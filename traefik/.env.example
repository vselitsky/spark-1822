# Copy to .env on the host and customize.

# Traefik image. Default tracks the v2.x line (https://hub.docker.com/_/traefik/tags)
# — auto-picks minor/patch updates, refuses to cross into v3.
#
# IMPORTANT: do NOT use `:latest` here — it resolves to v3.x, and Traefik v3
# dropped the named-capture HostRegexp syntax (`{name:regex}`) that every
# router rule in this repo uses. All six routers would go silent on a v3
# upgrade until the rules are migrated.
#
# v2.11 was the previous explicit pin and is the LTS line; bundles a Docker
# SDK that auto-negotiates the host's API version (v3.3 ships a stale SDK
# that gets refused by modern Docker daemons with "client version 1.24 is
# too old").
#
# In production, pin to an immutable tag (e.g. TRAEFIK_TAG=v2.11.X) in
# your local .env so deploys are reproducible.
TRAEFIK_TAG=v2
