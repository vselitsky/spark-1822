# Netdata image tag — pin to a known-good version.
# Releases: https://github.com/netdata/netdata/releases
NETDATA_TAG=v2.10.3

# Hostname Netdata reports itself as (default: spark-1822).
NETDATA_HOSTNAME=spark-1822

# GID of the host's `docker` group — Netdata needs it to read
# /var/run/docker.sock for container metrics.
# Find with: getent group docker | cut -d: -f3
DOCKER_GID=988
