# Copy to .env on the host and customize.

# cloudflared image. Default tracks `latest` for convenience.
# In production, pin to a specific version in your local .env for
# reproducibility. Tags: https://hub.docker.com/r/cloudflare/cloudflared/tags
CLOUDFLARED_TAG=latest

# Connector token from the Cloudflare dashboard:
#   Zero Trust → Networks → Tunnels → <tunnel> → Install connector → Docker
# It's a long base64-encoded string. Treat as a secret; .env is gitignored.
CLOUDFLARE_TUNNEL_TOKEN=
