# llama.cpp server image — pinned by content digest of the multi-arch
# manifest list so Docker picks the correct arch (arm64 on the host).
# Upstream publishes per-build tags amd64-only after b5343; the floating
# `server-cuda` tag is the only one shipping arm64+CUDA, so pin its digest.
#
# Find the current digest with:
#   TOK=$(curl -s 'https://ghcr.io/token?service=ghcr.io&scope=repository:ggml-org/llama.cpp:pull' | jq -r .token)
#   curl -sI -H "Authorization: Bearer $TOK" \
#     -H 'Accept: application/vnd.docker.distribution.manifest.list.v2+json' \
#     'https://ghcr.io/v2/ggml-org/llama.cpp/manifests/server-cuda' | grep -i docker-content-digest
LLAMACPP_TAG=server-cuda@sha256:a04923d31b4ca0d95bd772a4b80c9112f29121014df64d3d80a16a136ca19672

# Pick ONE model source. MODEL_PATH wins if both are set.
#
# (A) Use a pre-existing file inside the container. Mount points:
#       /ollama/models/blobs/sha256-<hex>     — Ollama-cached GGUF blobs
#       /root/.cache/huggingface/hub/...      — HuggingFace CLI cache
#     Find an Ollama-cached GGUF with:
#       docker run --rm -v open-webui-ollama:/data alpine \
#         sh -c 'cat /data/models/manifests/registry.ollama.ai/library/<model>/<tag> | jq -r '.layers[] | select(.mediaType=="application/vnd.ollama.image.model") | .digest'' \
#         | sed 's|sha256:|/ollama/models/blobs/sha256-|'
#MODEL_PATH=/ollama/models/blobs/sha256-XXXXXXXX
#
# (B) Download from a URL on first start (cached in the llama-cpp-cache volume
#     for subsequent runs). The default is gpt-oss-safeguard 120B MXFP4
#     (~65 GB across two split files); llama.cpp picks up the second split
#     from the same directory automatically.
MODEL_URL=https://huggingface.co/lmstudio-community/gpt-oss-safeguard-120b-GGUF/resolve/main/gpt-oss-safeguard-120b-MXFP4-00001-of-00002.gguf

# Name surfaced via the OpenAI-compatible API.
MODEL_ALIAS=gpt-oss-safeguard-120b

# Context window. The model itself supports much larger; pick what fits
# your VRAM budget alongside the weights.
CTX_SIZE=8192

# Number of model layers to offload to GPU. 999 = all (default).
N_GPU_LAYERS=999

# Host path that holds the HuggingFace CLI cache. Mounted read-only into
# the container. Default works for the `alexus` user on this host.
HF_CACHE_HOST=/home/alexus/.cache/huggingface

# Optional HuggingFace access token (gated/private models). Public models
# need nothing.
HF_TOKEN=
