# Host-wide llama.cpp config — values shared across every variant in
# envs/. Copy this to .env once (`make up` does it automatically on
# first run).
#
# `make up ENV=<name>` layers envs/<name>.env on top via a second
# --env-file flag, so the variant's model-specific values (MODEL_PATH /
# URL / OLLAMA, alias, any per-variant overrides) win over what's
# here. Raw `docker compose ps / logs / down` reads only this file.

# llama.cpp image. Default below tracks the floating multi-arch tag —
# convenient for first-time setup, BUT in production you should override
# this in your local .env with a content-digest pin so deploys are
# reproducible and upstream regressions can't sneak in (we've seen builds
# ship with broken RPATH/RUNPATH that crash on startup). The per-build
# tags `server-cuda-b<NNNN>` exist but are amd64-only single-arch — on
# arm64 they'd pull the amd64 layer under emulation and fail. Pin via:
#   LLAMACPP_TAG=server-cuda@sha256:<digest>
# Re-resolve the digest with the snippet in README → "Pinning the image".
LLAMACPP_TAG=server-cuda

# Host path holding the HuggingFace CLI cache. Mounted read-only.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models only). Public models
# need nothing.
HF_TOKEN=

# Default knobs — variants override per-model if needed.
MODEL_ALIAS=llama-cpp
CTX_SIZE=32768
N_GPU_LAYERS=999

# Model source — set in envs/<name>.env. Compose uses ${VAR:-} defaults
# for these, so leaving empty here is fine; raw `docker compose ps`
# etc. just won't have a model attached (which is correct for a
# placeholder state).
MODEL_PATH=
MODEL_OLLAMA=
MODEL_URL=

# --- Router mode (default when no MODEL_* is set) ---

# Host directory for the symlink farm — populated by `make hf-sync`,
# bind-mounted into the container at /models:ro. Router scans this directory.
SYMLINK_FARM_HOST=/opt/hf/.cache/llama-cpp-models

# Max models held resident in VRAM at once. LRU evicts the rest. Tune to:
#   MODELS_MAX × worst_case_resident_VRAM_GiB ≤ device_VRAM_GiB − headroom
# Default 2 because the 120b is ~65 GiB and the GB10 is 124 GiB total.
MODELS_MAX=2

# API key for the OpenAI-compat endpoint. Generate with `openssl rand -hex 32`.
# When non-empty, clients (OpenWebUI config, curl, scripts) must send
# `Authorization: Bearer $LLAMA_API_KEY`. Required for the Cloudflare Tunnel
# path (genuine internet exposure). Leave blank only for localhost-only testing.
LLAMA_API_KEY=
