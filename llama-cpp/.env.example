# Host-wide llama.cpp config — values shared across every variant in
# envs/. Copy this to .env once (`make up` does it automatically on
# first run).
#
# `make up ENV=<name>` layers envs/<name>.env on top via a second
# --env-file flag, so the variant's model-specific values (MODEL_PATH /
# URL / OLLAMA, alias, any per-variant overrides) win over what's
# here. Raw `docker compose ps / logs / down` reads only this file.

# llama.cpp image — `server-cuda-b<NNNN>` is the per-build tag for the
# CUDA server image (multi-arch arm64+amd64). Per-build tags are
# immutable on the registry, so just pinning the tag is enough — no
# digest-pin needed. Bump to a newer build by changing the number.
LLAMACPP_TAG=server-cuda-b9151

# Host path holding the HuggingFace CLI cache. Mounted read-only.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models only). Public models
# need nothing.
HF_TOKEN=

# Default knobs — variants override per-model if needed.
MODEL_ALIAS=llama-cpp
CTX_SIZE=8192
N_GPU_LAYERS=999

# Model source — set in envs/<name>.env. Compose uses ${VAR:-} defaults
# for these, so leaving empty here is fine; raw `docker compose ps`
# etc. just won't have a model attached (which is correct for a
# placeholder state).
MODEL_PATH=
MODEL_OLLAMA=
MODEL_URL=
