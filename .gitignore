# Secrets — never commit. Match .env at any depth (top-level, any subdirectory,
# any nested subdirectory). Three patterns belt-and-suspenders:
#   .env          — matches a .env file in the repo root
#   /**/.env      — matches a .env file at any nested path (Git ≥ 2.0)
#   **/.env       — equivalent; some tooling prefers this form
# Tracked .env-style auxiliary files (.env.example) are intentionally NOT
# matched and stay committed.
.env
/**/.env
**/.env

# Local-only compose overrides
**/docker-compose.override.yml
docker-compose.override.yml

# Per-stack env variants — generated locally via `envs/Makefile sync`.
# The Makefile and README in envs/ stay committed; the .env files don't.
**/envs/*.env

# Local backups (e.g. `make hf-sync` moves an env to .env.bak when the
# model leaves the remote HF cache; a future sync restores from .bak if
# it returns). Also catches *.bak from manual edits anywhere in the tree.
*.bak

# TLS material (Caddy local CA cert is host-specific; private keys never)
*.crt
*.key

# macOS
.DS_Store

# Editor cruft
*.swp
*~

# Claude Code local state
.claude/

# Vendor / host-shipped trees we don't manage in this repo
containerd
MicronTechnology
nvidia
NVIDIA AI Workbench
hf
