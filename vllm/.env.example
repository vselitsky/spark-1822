# Host-wide vLLM config — values shared across every variant in envs/.
# Copy this to .env once (`make up` does it automatically on first run).
#
# `make up ENV=<name>` layers envs/<name>.env on top via a second
# --env-file flag, so the variant's model-specific values (VLLM_MODEL,
# VLLM_SERVED_NAME, and any per-variant overrides) win over what's
# here. Raw `docker compose ps / logs / down` reads only this file —
# the placeholder VLLM_MODEL satisfies compose's ${VAR:?...} check but
# never reaches a real container.

# vLLM image. Multi-arch (amd64 + arm64). Default tracks `latest` for
# convenience. In production, pin to a specific release in your local .env
# (vLLM's minor versions can change CLI flags and compose contracts):
#   VLLM_TAG=v0.20.2
# Releases: https://github.com/vllm-project/vllm/releases
VLLM_TAG=latest

# Host path holding the HuggingFace CLI cache. Mounted read-write so
# vLLM and `hf` CLI share downloads.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models — meta-llama/*,
# etc.). Set once here; every variant gets it.
HF_TOKEN=

# Default GPU memory + context — variants override per-model if needed.
VLLM_GPU_MEM=0.9
VLLM_MAX_LEN=32768

# Placeholders for the model selection — variants in envs/<name>.env
# always override. Required by the compose file's :?-required checks
# so raw `docker compose <cmd>` doesn't error.
VLLM_MODEL=placeholder
VLLM_SERVED_NAME=placeholder
