# Common settings for every variant. Per-model settings live in envs/<name>.env
# and are layered on top via `make up VARIANT=<name>` (or `docker compose
# --env-file .env --env-file envs/<name>.env up -d`).
#
# vLLM image. Multi-arch (amd64 + arm64). Compute capability 12.1 (GB10)
# is not on vLLM's published support matrix — this stack is scaffolded but
# not yet smoke-tested on the host. Bring up at your own risk; first run
# may fail if sm_120 kernels aren't compiled into the image.
VLLM_TAG=v0.20.2

# Path on the host that holds the HuggingFace CLI cache. Mounted read-write
# so vLLM and `hf` CLI share the same downloads.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace access token (gated/private models — meta-llama/*, etc.)
HF_TOKEN=
